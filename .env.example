# PodcastIndex API (https://api.podcastindex.org) — register a free account for these.
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=

# RunPod API (https://www.runpod.io) — used for pod create/list/stop/terminate only;
# RunPod exposes no log-retrieval API, see infra/bootstrap.sh + pipeline/heartbeat.py.
RUNPOD_API_KEY=

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Hugging Face token with access to pyannote/speaker-diarization-3.1 and the
# embedding model's gated-model agreements accepted on huggingface.co.
HF_TOKEN=

# Budget / time guardrails (see pipeline/costs.py)
BUDGET_CAP_USD=100
TIME_CAP_HOURS=24
